# ╔══════════════════════════════════════════════════════════════╗
# ║         KATARA — Configuration (.env)                       ║
# ║         Copie ce fichier en ".env" et remplis les valeurs   ║
# ╚══════════════════════════════════════════════════════════════╝
#
# ⚠️  Ne jamais partager ce fichier (contient tes clés API !)
# ⚠️  Ajoute ".env" dans ton .gitignore

# ── OpenWeatherMap (météo temps réel) ──────────────────────────
# Gratuit sur : https://openweathermap.org/api
OWM_API_KEY=METS_TA_CLE_OWM_ICI

# ── Africa's Talking (SMS) ─────────────────────────────────────
# Gratuit sur : https://africastalking.com
# Utilise "sandbox" pour les tests
AT_USERNAME=sandbox
AT_API_KEY=METS_TA_CLE_AT_ICI
AT_SENDER=KATARA

# ── Google Earth Engine ─────────────────────────────────────────
# Gratuit pour ONG/recherche : https://earthengine.google.com
GEE_PROJECT=katara-flood-prediction

# ── Base de données ─────────────────────────────────────────────
KATARA_DB=katara.db

# ── Numéros équipe (rapport quotidien, séparés par virgules) ────
KATARA_TEAM_PHONES=+22890000000,+22891111111

# ── Supabase (optionnel — si tu veux une DB cloud) ──────────────
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_KEY=ta_cle_supabase
